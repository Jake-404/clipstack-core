# Clipstack Core — required env vars
# Copy to .env and fill in. Never commit .env.

# ─── Environment ────────────────────────────────────────────────────────────
# Influences stub-mode defaults across services and AUTH_STUB safety gates.
# Values: development (default) | test | production
NODE_ENV=development
# ENVIRONMENT mirrors NODE_ENV for the Python services (which don't read NODE_ENV).
ENVIRONMENT=development

# ─── Postgres (used by app, n8n metadata, langfuse metadata) ────────────────
POSTGRES_USER=clipstack
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=clipstack

# ─── Langfuse self-host ─────────────────────────────────────────────────────
LANGFUSE_NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
LANGFUSE_SALT=generate-with-openssl-rand-base64-16
LANGFUSE_INIT_USER_PASSWORD=change-me-on-first-login

# ─── LiteLLM router ─────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-clipstack-local-dev
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ─── Feature flags (orthogonal — platform must run with all `false`) ────────
CRYPTO_ENABLED=false
EVENTBUS_ENABLED=false
BANDITS_ENABLED=false
AGENT_BUDGET_AUTONOMOUS=false
SIGNALS_LOADED=core_only        # core_only | regulatory | full

# ─── Service URLs (compose-internal hostnames; override only for prod) ──────
DATABASE_URL=postgresql://clipstack:change-me-locally@postgres:5432/clipstack
DATABASE_POOL_MAX=20
QDRANT_URL=http://qdrant:6333
REDPANDA_BROKERS=redpanda:9092
LANGFUSE_HOST=http://langfuse:3000
LITELLM_HOST=http://litellm:4000
LITELLM_BASE_URL=http://litellm:4000
N8N_HOST=http://n8n:5678
OLLAMA_HOST=http://ollama:11434

# ─── Approval-UI service-token auth (used by Python agent services) ─────────
# Shared secret. Rotate via env var update; per-service token rotation lands A.3+.
SERVICE_TOKEN=change-me-generate-random-32+chars

# ─── Internal service URLs (consumed by agent-crewai + agent-langgraph) ─────
APPROVAL_UI_BASE_URL=http://approval-ui:3000
VOICE_SCORER_BASE_URL=http://voice-scorer:8005
PERCENTILE_PREDICTOR_BASE_URL=http://percentile-predictor:8007
BANDIT_ORCHESTRATOR_BASE_URL=http://bandit-orchestrator:8008
PII_DETECTION_BASE_URL=http://pii-detection:8003
OUTPUT_MODERATION_BASE_URL=http://output-moderation:8004
PERFORMANCE_INGEST_BASE_URL=http://performance-ingest:8006

# ─── Stub-mode flags (default depends on environment) ───────────────────────
# Each service flips its real backend off when its STUB_MODE flag is "1".
# Default: "1" in dev/test, "0" in production. Setting "1" in production is
# permitted but each service logs a structured warning per request.
PII_STUB_MODE=
MODERATION_STUB_MODE=
VOICE_SCORER_STUB_MODE=
PREDICTOR_STUB_MODE=
BANDIT_STUB_MODE=
INGEST_STUB_MODE=
CREWAI_DRY_RUN=
LANGGRAPH_DRY_RUN=

# ─── Auth stub (DEV/TEST ONLY — refused at runtime when NODE_ENV=production)─
# Setting both makes every request return a fake owner-role session for the
# given user/company. Use only for local dev + early integration tests; remove
# both before the WorkOS slice ships.
AUTH_STUB_USER_ID=
AUTH_STUB_COMPANY_ID=

# ─── Auth (Phase A.1 — WorkOS for SSO/SAML, A.2 follow-up) ──────────────────
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# ─── Web3 (Phase 5 — disabled when CRYPTO_ENABLED=false) ────────────────────
COINBASE_CDP_API_KEY=
COINBASE_CDP_API_SECRET=
BASE_RPC_URL=https://sepolia.base.org   # mainnet promotion gated by $50K MRR
